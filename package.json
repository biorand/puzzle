{
  "name": "repuzzles",
  "private": true,
  "scripts": {
    "build": "esbuild src/main.ts --bundle --outfile=dist/app.min.js --minify",
    "dev": "esbuild src/main.ts --bundle --outfile=dist/app.min.js --sourcemap --watch=forever & sleep 1 && npx http-server . -p 8000 -c-1"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "http-server": "^14.1.1",
    "typescript": "^5.7.0"
  }
}
