{
    "name": "repuzzles",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "esbuild src/main.ts --bundle --outfile=dist/app.min.js --minify",
        "dev": "node scripts/dev.mjs",
        "format": "prettier --write \"src/**/*.ts\" \"*.html\" \"*.css\" \"*.md\" \"*.json\"",
        "format:check": "prettier --check \"src/**/*.ts\" \"*.html\" \"*.css\" \"*.md\" \"*.json\"",
        "lint": "eslint \"src/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" --fix",
        "test": "vitest run",
        "test:watch": "vitest",
        "e2e": "node scripts/e2e.mjs",
        "verify": "npm run format && npm run lint && npm run test && npm run e2e"
    },
    "dependencies": {
        "lit": "^3.2.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@playwright/test": "^1.61.0",
        "esbuild": "^0.25.0",
        "eslint": "^9.17.0",
        "eslint-plugin-lit": "^1.15.0",
        "get-port": "^7.2.0",
        "globals": "^15.14.0",
        "happy-dom": "^20.10.6",
        "http-server": "^14.1.1",
        "prettier": "^3.4.0",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.18.0",
        "vitest": "^4.1.9"
    }
}
